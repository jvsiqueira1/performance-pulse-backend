{
  "name": "performance-pulse-backend",
  "version": "0.1.0",
  "description": "Backend Fastify + Prisma + Postgres do Performance Pulse",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
