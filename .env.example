# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://pulse:pulse@localhost:5432/performance_pulse?schema=public

# Auth
JWT_SECRET=change-me-in-production-pls-use-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS (lista separada por virgula; regex /\.vercel\.app$/ sempre aceita)
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=2

# OpenRouter (Fase 10)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5-20251001

# Seed
SEED_ADMIN_EMAIL=felipe@empresa.com
SEED_ADMIN_PASSWORD=troque-na-primeira-execucao
SEED_ADMIN_NAME=Felipe
