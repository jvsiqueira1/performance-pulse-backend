# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────────────────────
# Dev local: docker compose up -d postgres (porta 5433 pra não conflitar com Postgres nativo)
DATABASE_URL=postgresql://pulse:pulse@localhost:5433/performance_pulse?schema=public

# ─── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────
# Lista separada por vírgula. Regex /\.vercel\.app$/ sempre é aceita (previews).
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# ─── Uploads ───────────────────────────────────────────────────────────────
# Limite máximo do arquivo no multipart (MB). O backend resize pra 256x256
# JPEG antes de gravar, então 10MB é margem de segurança pra fotos modernas.
MAX_UPLOAD_SIZE_MB=10

# ─── Cloudflare R2 (obrigatório em qualquer ambiente) ─────────────────────
# Crie um bucket em https://dash.cloudflare.com/?to=/:account/r2
# Crie API Token com permissão "Object Read & Write" nesse bucket.
# O backend exige essas vars — não há fallback local.
#
# R2_ACCOUNT_ID: encontrado no dashboard R2 (canto superior direito, "Account ID")
R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID e R2_SECRET_ACCESS_KEY: gerados ao criar API Token
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Nome do bucket (ex: performance-pulse-photos)
R2_BUCKET=
# URL pública onde as fotos serão servidas. Duas opções:
# (a) r2.dev (dev/teste): https://pub-<hash>.r2.dev
# (b) custom domain (prod recomendado): https://cdn.pulse.empresa.com
# O backend concatena /assessors/{id}.jpg ao final.
R2_PUBLIC_URL=
# Endpoint S3-compatible. Se omitido, derivado de R2_ACCOUNT_ID automaticamente:
# https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=

# ─── OpenRouter (IA Insights) ─────────────────────────────────────────────
# Obtenha em https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ─── Seed (admin inicial) ─────────────────────────────────────────────────
SEED_ADMIN_EMAIL=seu-email@empresa.com
SEED_ADMIN_PASSWORD=senha-segura-min-8-chars
SEED_ADMIN_NAME=Seu Nome
