// Performance Pulse — Fase 2
// 17 models + 11 enums cobrindo todo o domínio do dashboard de gamificação.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
}

enum AssessorLevel {
  BRONZE
  SILVER
  GOLD
}

enum KpiInputMode {
  ABSOLUTE
  PERCENT
  QUANTITY_OVER_BASE
}

enum GoalPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum CadenceType {
  WEEKLY
  BIWEEKLY
}

enum MeetingOutcomeStatus {
  SCHEDULED
  NO_SHOW
  DONE
  CLOSED_WON
  CLOSED_LOST
}

enum BetType {
  WEEKLY
  MONTHLY
  CUSTOM
}

enum BetStatus {
  ACTIVE
  FINISHED
  CANCELED
}

/// Distingue bet squad-vs-squad (histórico) de torneios com goal+prêmio progressivo.
enum CompetitionKind {
  SQUAD_BET
  TOURNAMENT
}

/// Escopo de um torneio — individual (cada assessor corre) ou squad (times).
enum TournamentScope {
  INDIVIDUAL
  SQUAD
}

enum CofreEntryKind {
  DEPOSIT
  PAYOUT
  ADJUSTMENT
}

enum BadgeScope {
  INDIVIDUAL
  SQUAD
}

enum InsightPeriod {
  DAY
  WEEK
  MONTH
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// Admin/gestor login — assessores NÃO logam.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  metricEntries       MetricEntry[]
  goalsCreated        Goal[]
  betsCreated         Bet[]
  cofreEntries        CofreEntry[]
  prizesAwarded       Prize[]
  directionsWritten   DailyDirection[]
  directionsReviewed  DailyDirection[] @relation("DirectionReviewer")
  announcementsAuthor Announcement[]

  @@map("users")
}

/// Representante de vendas (entidade gerenciada, sem login).
/// points, streak, weeklyGoalPercent, kpis.* são DERIVADOS de MetricEntry.
model Assessor {
  id            String        @id @default(cuid())
  name          String
  initials      String
  photoUrl      String?
  level         AssessorLevel @default(BRONZE)
  active        Boolean       @default(true)
  totalLeads    Int           @default(0)
  totalClients  Int           @default(0)
  vacationUntil DateTime?     @db.Date
  hiredAt       DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  metricEntries     MetricEntry[]
  badgeUnlocks      BadgeUnlock[]
  aiInsights        AiInsight[]
  meetingOutcomes   MeetingOutcome[]
  prizes            Prize[]
  squadMemberships  SquadMember[]
  leaderOfSquads    Squad[]          @relation("SquadLeader")
  betParticipations BetParticipant[] @relation("AssessorBetParticipant")

  @@index([active])
  @@map("assessors")
}

/// Definição de KPI editável — substitui KPI_META hardcoded.
model Kpi {
  id             String       @id @default(cuid())
  key            String       @unique
  label          String
  unit           String       @default("")
  inputMode      KpiInputMode @default(ABSOLUTE)
  baseSource     String?
  defaultTarget  Float
  isDerived      Boolean      @default(false)
  derivedFormula String?
  sortOrder      Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  goals         Goal[]
  metricEntries MetricEntry[]
  activityKpis  ActivityKpi[]
  scoringRule   ScoringRule?

  @@index([active, sortOrder])
  @@map("kpis")
}

/// Regra de pontuação por KPI. Define quanto cada unidade vale.
/// Antes era hardcoded em scoring.ts; movida pro banco em 17/04/2026 pra
/// permitir edição via UI sem deploy.
///
/// Tipos:
/// - LINEAR: pontos = floor(rawValue / divisor) * pointsPerBucket
///   Ex: lead = 1 pt → divisor=1, pointsPerBucket=1
///   Ex: 10 boletas = 1 pt → divisor=10, pointsPerBucket=1
///   Ex: 30 prosp = 5 pts → divisor=30, pointsPerBucket=5
/// - THRESHOLD_PERCENT: pontos = (convertedPercent >= thresholdPct) ? thresholdPoints : 0
///   Ex: cadência ≥70% = 5 pts → thresholdPct=70, thresholdPoints=5
model ScoringRule {
  id              String          @id @default(cuid())
  kpiId           String          @unique
  kpi             Kpi             @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  ruleType        ScoringRuleType
  // LINEAR fields
  divisor         Float? // ex: 1 pra per-unit, 10 pra "10 boletas = 1 pt"
  pointsPerBucket Float? // ex: 1 pra "1 ponto a cada divisor"
  // THRESHOLD_PERCENT fields
  thresholdPct    Float? // ex: 70 = ≥70% da meta
  thresholdPoints Float? // ex: 5 pts quando atinge threshold
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@map("scoring_rules")
}

enum ScoringRuleType {
  LINEAR
  THRESHOLD_PERCENT
}

/// Meta historizável por KPI — suporta aplicação retroativa.
model Goal {
  id                   String     @id @default(cuid())
  kpiId                String
  kpi                  Kpi        @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  value                Float
  period               GoalPeriod
  validFrom            DateTime
  validTo              DateTime?
  appliesRetroactively Boolean    @default(false)
  createdById          String
  createdBy            User       @relation(fields: [createdById], references: [id])
  createdAt            DateTime   @default(now())

  @@index([kpiId, validFrom])
  @@index([kpiId, validTo])
  @@map("goals")
}

/// Item do cronograma semanal (ex: "Geração Lista Prospecção", segunda manhã).
model Activity {
  id                 String      @id @default(cuid())
  name               String
  description        String?
  dayOfWeek          Int // 1=seg .. 5=sex
  startTime          String // "HH:mm"
  endTime            String // "HH:mm"
  cadenceType        CadenceType @default(WEEKLY)
  biweeklyAnchorDate DateTime?   @db.Date
  sortOrder          Int         @default(0)
  active             Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  kpis          ActivityKpi[]
  metricEntries MetricEntry[]

  @@index([dayOfWeek, active])
  @@index([cadenceType])
  @@map("activities")
}

/// Join Activity↔Kpi com target override opcional.
model ActivityKpi {
  id             String   @id @default(cuid())
  activityId     String
  activity       Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  kpiId          String
  kpi            Kpi      @relation(fields: [kpiId], references: [id], onDelete: Restrict)
  targetOverride Float?

  @@unique([activityId, kpiId])
  @@map("activity_kpis")
}

/// Timeseries core — entrada diária por assessor/KPI.
/// rawValue é fonte de verdade; convertedPercent e pointsAwarded são cache.
model MetricEntry {
  id               String    @id @default(cuid())
  assessorId       String
  assessor         Assessor  @relation(fields: [assessorId], references: [id], onDelete: Cascade)
  kpiId            String
  kpi              Kpi       @relation(fields: [kpiId], references: [id], onDelete: Restrict)
  activityId       String?
  activity         Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  date             DateTime  @db.Date
  rawValue         Float
  baseValue        Float?
  convertedPercent Float?
  pointsAwarded    Float?
  enteredById      String
  enteredBy        User      @relation(fields: [enteredById], references: [id])
  notes            String?
  /// Marcado quando a entry foi criada/editada em data DIFERENTE do `date` da
  /// métrica (Felipe pediu visibilidade pra "pontuação retroativa").
  /// Ex: hoje 19/abr admin upserta métrica com date=15/abr → backfilledAt=now().
  /// Null = entry registrada no próprio dia (caso normal).
  backfilledAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  scheduledMeeting MeetingOutcome?

  @@unique([assessorId, kpiId, activityId, date])
  @@index([date])
  @@index([assessorId, date])
  @@index([kpiId, date])
  @@map("metric_entries")
}

/// Captura outcome de reuniões (marcou vs fechou).
model MeetingOutcome {
  id                     String               @id @default(cuid())
  assessorId             String
  assessor               Assessor             @relation(fields: [assessorId], references: [id], onDelete: Cascade)
  scheduledDate          DateTime
  scheduledMetricEntryId String?              @unique
  scheduledMetricEntry   MetricEntry?         @relation(fields: [scheduledMetricEntryId], references: [id], onDelete: SetNull)
  outcome                MeetingOutcomeStatus @default(SCHEDULED)
  closedAt               DateTime?
  ticketValue            Float?
  notes                  String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([assessorId, scheduledDate])
  @@index([outcome])
  @@map("meeting_outcomes")
}

/// Squad de vendas.
model Squad {
  id        String   @id @default(cuid())
  name      String
  emoji     String
  color     String
  leaderId  String
  leader    Assessor @relation("SquadLeader", fields: [leaderId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      SquadMember[]
  wonBets      Bet[]            @relation("BetWinner")
  participants BetParticipant[]
  badgeUnlocks BadgeUnlock[]
  aiInsights   AiInsight[]

  @@map("squads")
}

/// Join Squad↔Assessor com histórico (leftAt pra saber quem estava quando).
model SquadMember {
  id         String    @id @default(cuid())
  squadId    String
  squad      Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  assessorId String
  assessor   Assessor  @relation(fields: [assessorId], references: [id], onDelete: Cascade)
  joinedAt   DateTime  @default(now())
  leftAt     DateTime?

  @@unique([squadId, assessorId, leftAt])
  @@index([assessorId])
  @@map("squad_members")
}

/// Squad bet OU torneio — campo `kind` distingue.
/// SQUAD_BET: aposta squad-vs-squad (winner-take-all).
/// TOURNAMENT: corrida com meta + prêmio progressivo (top N).
model Bet {
  id                 String    @id @default(cuid())
  roundLabel         String
  type               BetType
  value              Float
  startDate          DateTime  @db.Date
  endDate            DateTime  @db.Date
  status             BetStatus @default(ACTIVE)
  winnerSquadId      String?
  winnerSquad        Squad?    @relation("BetWinner", fields: [winnerSquadId], references: [id])
  winnerCriteriaJson Json
  createdById        String
  createdBy          User      @relation(fields: [createdById], references: [id])
  createdAt          DateTime  @default(now())
  finishedAt         DateTime?

  // ── Tournament extensions (kind=TOURNAMENT) ─────────────────────────────
  /// Default SQUAD_BET mantém compat — bets existentes não mudam de comportamento.
  kind                  CompetitionKind  @default(SQUAD_BET)
  /// Escopo do torneio — só preenchido se kind=TOURNAMENT.
  tournamentScope       TournamentScope?
  /// Top N ganhadores (default 1). Usado pra payout progressivo.
  maxWinners            Int?
  /// Payout progressivo: {"1": 300, "2": 150, "3": 100}. Se null, `value` vai pro 1º.
  progressivePayoutJson Json?
  /// KPI da corrida (ex: "ativacao_conta"). Torneio threshold-race usa + goalTargetValue.
  goalKpiKey            String?
  /// Meta numérica do torneio (ex: primeiro a 50). Opcional.
  goalTargetValue       Float?

  participants BetParticipant[]
  cofreEntries CofreEntry[]

  @@index([status])
  @@index([endDate])
  @@index([kind])
  @@map("bets")
}

/// Participante de uma competição.
/// SQUAD_BET / TOURNAMENT scope=SQUAD: squadId preenchido, assessorId null.
/// TOURNAMENT scope=INDIVIDUAL: assessorId preenchido, squadId null.
/// Exatamente um dos dois deve estar preenchido (validado no serviço).
model BetParticipant {
  id                  String    @id @default(cuid())
  betId               String
  bet                 Bet       @relation(fields: [betId], references: [id], onDelete: Cascade)
  squadId             String?
  squad               Squad?    @relation(fields: [squadId], references: [id])
  assessorId          String?
  assessor            Assessor? @relation("AssessorBetParticipant", fields: [assessorId], references: [id])
  /// Snapshot de membros no momento em que o squad entrou (só pra SQUAD scope).
  snapshotMembersJson Json?
  finalScore          Float?
  /// Rank final após finish (1=vencedor). Null enquanto bet/torneio ACTIVE.
  rank                Int?

  @@unique([betId, squadId])
  @@unique([betId, assessorId])
  @@map("bet_participants")
}

/// Ledger do cofre (entradas/saídas).
model CofreEntry {
  id          String         @id @default(cuid())
  betId       String?
  bet         Bet?           @relation(fields: [betId], references: [id])
  kind        CofreEntryKind
  amount      Float
  description String
  createdById String
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([createdAt])
  @@index([betId])
  @@map("cofre_entries")
}

/// Definição de badge (individual ou squad).
/// ruleJson define a lógica de desbloqueio.
model Badge {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  description String
  icon        String
  scope       BadgeScope
  ruleJson    Json
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  unlocks BadgeUnlock[]

  @@map("badges")
}

/// Registro de desbloqueio de badge — idempotente por periodKey.
model BadgeUnlock {
  id         String    @id @default(cuid())
  badgeId    String
  badge      Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  assessorId String?
  assessor   Assessor? @relation(fields: [assessorId], references: [id], onDelete: Cascade)
  squadId    String?
  squad      Squad?    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  unlockedAt DateTime  @default(now())
  periodKey  String

  @@unique([badgeId, assessorId, periodKey])
  @@unique([badgeId, squadId, periodKey])
  @@index([unlockedAt])
  @@map("badge_unlocks")
}

/// Cache de insights gerados por IA (OpenRouter).
model AiInsight {
  id           String        @id @default(cuid())
  assessorId   String?
  assessor     Assessor?     @relation(fields: [assessorId], references: [id], onDelete: Cascade)
  squadId      String?
  squad        Squad?        @relation(fields: [squadId], references: [id], onDelete: Cascade)
  periodKind   InsightPeriod
  periodKey    String
  model        String
  inputHash    String
  textMarkdown String
  summary      String
  tags         String[]
  createdAt    DateTime      @default(now())

  @@unique([assessorId, periodKind, periodKey, inputHash])
  @@index([assessorId, periodKind, periodKey])
  @@map("ai_insights")
}

/// Premiação individual de assessor (vale-refeição, day off, etc).
model Prize {
  id          String   @id @default(cuid())
  assessorId  String
  assessor    Assessor @relation(fields: [assessorId], references: [id], onDelete: Cascade)
  title       String
  description String?
  period      String // "2026-W15", "2026-04", etc
  awardedById String
  awardedBy   User     @relation(fields: [awardedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([assessorId])
  @@index([period])
  @@map("prizes")
}

/// Configurações globais do sistema (anchor indique day default, frases TV, etc).
model SystemConfig {
  key         String   @id
  valueJson   Json
  updatedById String
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

/// Direcionamento diário editável (foco do dia, orientações do coordenador).
/// Um registro por data — UPSERT no PUT /api/directions/:date.
/// Direcionamento (Foco) com período + KPIs alvo + status de cumprimento.
/// Mantém o nome `DailyDirection` por compat — agora suporta DAILY/WEEKLY/MONTHLY
/// via campo `period`. Registros existentes ficam DAILY (default).
model DailyDirection {
  id          String   @id @default(cuid())
  /// Pra DAILY: a data do dia. Pra WEEKLY: segunda da semana. Pra MONTHLY: dia 1 do mês.
  date        DateTime @unique @db.Date
  text        String
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ── Sprint B (Felipe): foco com período + cumprimento ───────────────────
  period        DirectionPeriod @default(DAILY)
  /// Default = `date`. Pra WEEKLY/MONTHLY explícito quando precisa range custom.
  periodStart   DateTime?       @db.Date
  periodEnd     DateTime?       @db.Date
  /// Quais KPIs o foco prevê elevar (ex: ["ativacao_conta", "ligacoes"])
  targetKpiKeys String[]        @default([])
  status        DirectionStatus @default(PENDING)
  reviewNote    String?
  reviewedAt    DateTime?
  reviewedById  String?
  reviewedBy    User?           @relation("DirectionReviewer", fields: [reviewedById], references: [id])

  @@index([date])
  @@index([period, date])
  @@map("daily_directions")
}

enum DirectionPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum DirectionStatus {
  PENDING
  ACHIEVED
  PARTIAL
  MISSED
}

/// Avisos manuais que rolam no AnnouncementTicker do dashboard.
/// Independentes das mensagens auto-geradas (líder, streaks, etc).
/// Felipe edita via Admin → Avisos.
model Announcement {
  id          String    @id @default(cuid())
  message     String
  emoji       String?
  active      Boolean   @default(true)
  expiresAt   DateTime?
  sortOrder   Int       @default(0)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([active, sortOrder])
  @@map("announcements")
}
